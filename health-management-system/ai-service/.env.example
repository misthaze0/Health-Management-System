# Kimi (Moonshot) AI服务环境变量配置
# 复制此文件为 .env 并填写实际值

# 服务配置
APP_NAME=Health Management AI Service
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=19002

# Kimi (Moonshot) API配置
MOONSHOT_API_KEY=your-moonshot-api-key-here
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=moonshot-v1-8k
MOONSHOT_TIMEOUT=60

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/ai_service.log

    "dayjs": "^1.11.10",
    "echarts": "^5.4.3",
    "element-plus": "^2.5.1",
    "js-cookie": "^3.0.5",
    "nprogress": "^0.2.0",
    "ogl": "^1.0.11",
    "pinia": "^2.1.7",
    "vditor": "^3.11.2",
    "vue": "^3.4.15",
    "vue-cropper": "^1.1.4",
    "vue-echarts": "^6.6.8",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@testing-library/vue": "^8.1.0",
    "@vitejs/plugin-vue": "^5.0.3",
